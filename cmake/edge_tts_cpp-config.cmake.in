# edge_tts_cpp-config.cmake — CMake package configuration for edge-tts-cpp.
#
# Generated by CMakePackageConfigHelpers; do not edit directly.
#
# Usage:
#   find_package(edge_tts_cpp REQUIRED)
#   target_link_libraries(myapp PRIVATE edge_tts::tts)
#
# Available targets after find_package:
#   edge_tts::tts            — recommended entry point (links api + all deps)
#   edge_tts::api            — synthesis facade
#   edge_tts::communication  — WebSocket/HTTP transport (advanced)
#   edge_tts::serialization  — SSML/protocol framing (advanced)
#   edge_tts::subtitle       — SRT subtitle generation (advanced)
#   edge_tts::core           — core domain types (advanced)
#   edge_tts::common         — utilities and error types (advanced)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# ixwebsocket (when compiled with TLS and gzip support) references ZLIB and
# Threads as IMPORTED targets in the generated targets file.  Locate them so
# consumers who find_package(edge_tts_cpp) do not get "target not found" errors.
find_dependency(ZLIB QUIET)
find_dependency(Threads QUIET)

include("${CMAKE_CURRENT_LIST_DIR}/edge_tts_cpp-targets.cmake")

# The export file imports targets without a namespace prefix (edge_tts_common,
# edge_tts_tts, etc.) to avoid a double-prefix (edge_tts::edge_tts_tts).
# Create edge_tts::<name> ALIAS targets here so that consumers use the
# conventional namespace form.
#
# set_target_properties(IMPORTED_GLOBAL TRUE) is required before aliasing an
# IMPORTED target; available since CMake 3.18 (our minimum is 3.24).
foreach(_edge_tts_mod common core serialization subtitle communication api tts)
    set(_edge_tts_tgt "edge_tts_${_edge_tts_mod}")
    if(TARGET "${_edge_tts_tgt}" AND NOT TARGET "edge_tts::${_edge_tts_mod}")
        set_target_properties("${_edge_tts_tgt}" PROPERTIES IMPORTED_GLOBAL TRUE)
        add_library("edge_tts::${_edge_tts_mod}" ALIAS "${_edge_tts_tgt}")
    endif()
    unset(_edge_tts_tgt)
endforeach()
unset(_edge_tts_mod)

check_required_components(edge_tts_cpp)
