---
# Placeholder — expand as the codebase matures.
# Run via: cmake -DEDGE_TTS_ENABLE_CLANG_TIDY=ON

Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  bugprone-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-default-member-init,
  performance-unnecessary-copy-initialization,
  readability-identifier-naming

# Turn off checks that fire too early on stub/skeleton code.
# Remove suppressions as implementation fills in.
CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelCase
  - key: readability-identifier-naming.VariableCase
    value: camelCase
  - key: readability-identifier-naming.MemberCase
    value: camelCase
  - key: readability-identifier-naming.ParameterCase
    value: camelCase

WarningsAsErrors: ''
HeaderFilterRegex: 'include/edge_tts/.*'
